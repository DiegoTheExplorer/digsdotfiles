{
	"height": 24,
	"layer": "top", // Waybar at top layer
	"position": "top", // Waybar position (top|bottom|left|right)
	// "width": 1280, // Waybar width
	// Choose the order of the modules
	"modules-left": ["hyprland/workspaces", "keyboard-state"],
	"modules-center": ["custom/music"],
	"modules-right": ["pulseaudio", "backlight", "battery", "clock", "tray", "custom/lock", "custom/power"],
	"hyprland/workspaces": {
	 "disable-scroll": true,
	 "sort-by-name": true,
	 "format": " {icon} ",
	 "format-icons": {
	     "default": "Όχ┤",
	 },
	},
	"tray": {
	"icon-size": 21,
	"spacing": 10
	},
	"custom/music": {
	"format": "ΎΑΒ  {}",
	"escape": true,
	"interval": 5,
	"tooltip": false,
	"exec": "playerctl metadata --format='{{ title }}'",
	"on-click": "playerctl play-pause",
	"max-length": 50
	},
	"clock": {
	"tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
	"format-alt": "ΎΒ│ {:%d/%m/%Y}",
	"format": "≤░ξΦ {:%H:%M}"
	},
	"backlight": {
	"device": "intel_backlight",
	"format": "{icon} {percent}%",
	"format-icons": ["ΌΟΞ", "ΌΠΥ", "ΌΠΣ", "ΌΠΠ", "ΌΠΟ", "ΌΠΞ", "ΌΠΛ", "ΌΠΙ", "ΌΟδ"]
	},
	"battery": {
		"states": {
			"warning": 30,
			"critical": 15
		},
		"format": "{icon} {capacity}%",
		"format-charging": "≤░ΓΕ {capacity}%",
		"format-plugged": "≤░ΓΠ",
		"format-alt": "{icon} {capacity}%",
		"format-icons": ["≤░Β║", "≤░Β╗",  "≤░Β╝", "≤░Β╜", "≤░Β╛", "≤░Β┐", "≤░ΓΑ", "≤░ΓΒ", "≤░Β╣"]
	},
	"pulseaudio": {
	// "scroll-step": 1, // %, can be a float
	"format": "{icon} {volume}%",
	"format-muted": "ΎΣο",
	"format-icons": {
	    "default": ["ΎΑο", "ΎΑπ", "ΎΑρ "]
	},
	"on-click": "pavucontrol"
	},
	"custom/lock": {
	"tooltip": false,
	"on-click": "pidof hyprlock || hyprlock",
	"format": "ΎΑμ",
	},
	"custom/power": {
	"tooltip": false,
	"on-click": "shutdown now",
	"format": "έΠ╗"
	},
	"keyboard-state": {
	    "capslock": true,
		"device-path": "/dev/input/by-path/platform-i8042-serio-0-event-kbd",
	    "format": "{name} {icon}",
	    "format-icons": {
		"locked": "ΎΑμ",
		"unlocked": "ΎΜ╝"
	    }
	}
}
